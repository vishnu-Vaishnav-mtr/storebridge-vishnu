{
  "name": "storebridge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @storebridge/web dev",
    "dev:worker": "pnpm --filter @storebridge/worker dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @storebridge/database prisma:generate",
    "db:migrate": "pnpm --filter @storebridge/database prisma:migrate",
    "db:seed": "pnpm --filter @storebridge/database seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.18.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
